{
  "name": "api",
  "version": "1.0.0",
  "description": "API do Sistema de Gerenciamento de Biblioteca",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "sequelize-cli db:migrate --options-path sequelize.options.json",
    "migrate:undo": "sequelize-cli db:migrate:undo:all --options-path sequelize.options.json",
    "migrate:status": "sequelize-cli db:migrate:status --options-path sequelize.options.json",
    "seed": "sequelize-cli db:seed:all --options-path sequelize.options.json",
    "seed:undo": "sequelize-cli db:seed:undo:all --options-path sequelize.options.json"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "pg": "^8.16.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.5"
  }
}
